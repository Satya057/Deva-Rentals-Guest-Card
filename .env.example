PORT=3000

# SMTP: account that has the App Password (sends mail “from” this address).
GMAIL_USER=rentalsdeva@gmail.com
GMAIL_APP_PASSWORD=

# Where form emails are delivered (can differ from GMAIL_USER).
MAIL_TO=showings.devarentals@gmail.com

# Set to 1 to stop BCC copy to GMAIL_USER when MAIL_TO is different (default: BCC on).
# MAIL_BCC_SUPPRESS=1

# Google Calendar API — from OAuth Playground + Cloud Console Web client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Showings are in local wall time for this zone (Alberta / Edmonton). Overrides browser if set.
CALENDAR_TIME_ZONE=America/Edmonton

# Optional
# GCAL_CREATE_SECRET=
